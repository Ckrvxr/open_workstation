{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "experimental": {
    "quotaToast": {
      "enableToast": false,
      "tuiSidebarPanel": {
        "enabled": true
      }
    }
  },
  "mcp": {
    "backgroundProcess": {
      "type": "local",
      "command": [
        "bgpm"
      ],
      "enabled": true
    },
    "lsp": {
      "type": "local",
      "command": ["node", "/home/cute/.local/share/opencode/lsp-tools-mcp/dist/cli.js", "mcp"],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "engram": {
      "command": [
        "/home/linuxbrew/.linuxbrew/bin/engram",
        "mcp",
        "--tools=agent"
      ],
      "enabled": true,
      "type": "local"
    },
    // "exa": {
    //   "type": "remote",
    //   "url": "https://mcp.exa.ai/mcp",
    //   "enabled": false,
    //   "headers": {
    //     "x-api-key": "{env:EXA_API_KEY}"
    //   }
    // },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PERSONAL_ACCESS_TOKEN}",
        "X-MCP-Toolsets": "default,actions"
      }
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    },
    "academix": {
      "type": "local",
      "command": [
        "academix"
      ],
      "enabled": true,
      "env": {
        "ACADEMIX_EMAIL": "{env:OPENALEX_EMAIL}"
      }
    },
    "open-computer-use": {
      "type": "local",
      "command": [
        "open-computer-use",
        "mcp"
      ]
    }
  },
  "permission": {
    "websearch": "allow"
  },
  "plugin": [
    "@slkiser/opencode-quota@latest",
    "opencode-secret-redactor@latest"
  ],
  "provider": {
    // Detected openai authentication; opencode-quota added this global provider declaration.
    "openai": {},
    // Detected opencode-go authentication; opencode-quota added this global provider declaration.
    "opencode-go": {},
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama Local",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "gemma4:e4b": {
          "name": "Gemma 4:E4B "
        }
      }
    }
  }
}
