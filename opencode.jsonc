{
  "$schema": "https://opencode.ai/config.json",
  "experimental": {
    "quotaToast": {
      "enableToast": false,
      "tuiSidebarPanel": {
        "enabled": true
      }
    }
  },
  "mcp": {
    "backgroundProcess": {
      "type": "local",
      "command": [
        "bgpm"
      ],
      "enabled": true
    },
    // "context7": {
    //   "type": "remote",
    //   "url": "https://mcp.context7.com/mcp",
    //   "enabled": true,
    //   "headers": {
    //     "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
    //   }
    // },
    "engram": {
      "command": [
        "/home/linuxbrew/.linuxbrew/bin/engram",
        "mcp",
        "--tools=agent"
      ],
      "enabled": true,
      "type": "local"
    },
    // "exa": {
    //   "type": "remote",
    //   "url": "https://mcp.exa.ai/mcp",
    //   "enabled": false,
    //   "headers": {
    //     "x-api-key": "{env:EXA_API_KEY}"
    //   }
    // },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PERSONAL_ACCESS_TOKEN}",
        "X-MCP-Toolsets": "default,actions"
      }
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    },
    "academix": {
      "type": "local",
      "command": [
        "academix"
      ],
      "enabled": true,
      "env": {
        "ACADEMIX_EMAIL": "{env:OPENALEX_EMAIL}"
      }
    },
    "open-computer-use": {
      "type": "local",
      "command": [
        "open-computer-use",
        "mcp"
      ]
    },
    "docker": {
      "type": "local",
      "command": [
        "/home/cute/.local/share/pnpm/bin/docker-mcp"
      ],
      "environment": {
        "DOCKER_MCP_LOCAL": "true"
      },
      "enabled": true
    }
  },
  "permission": {
    "websearch": "allow"
  },
  "plugin": [
    "@slkiser/opencode-quota@latest",
    "opencode-secret-redactor@latest"
  ]
}