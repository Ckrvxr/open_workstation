{
  "$schema": "https://opencode.ai/config.json",
  "experimental": {
    "quotaToast": {
      "enableToast": false,
      "tuiSidebarPanel": {
        "enabled": true
      }
    }
  },
  "mcp": {
    "backgroundProcess": {
      "type": "local",
      "command": [
        "bgpm"
      ],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "engram": {
      "command": [
        "/home/linuxbrew/.linuxbrew/bin/engram",
        "mcp",
        "--tools=agent"
      ],
      "enabled": true,
      "type": "local"
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true,
      "headers": {
        "x-api-key": "{env:EXA_API_KEY}"
      }
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "officecli": {
      "type": "local",
      "command": [
        "officecli",
        "mcp"
      ],
      "enabled": true
    }
  },
  "permission": {
    "websearch": "allow"
  },
  "plugin": [
    "@slkiser/opencode-quota@latest",
    "opencode-secret-redactor@latest"
  ]
}